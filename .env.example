# Copy this file to .env.local and fill in your real values.
# .env.local is already in .gitignore — never commit real keys.

# Anthropic API key (get one at https://console.anthropic.com)
ANTHROPIC_API_KEY=

# Database connection string (from Supabase or Neon — Stage 1)
DATABASE_URL=

# Auth secret (Stage 1) — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000
