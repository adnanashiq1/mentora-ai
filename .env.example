# Copy this file to .env.local and fill in your real values.
# .env.local is already in .gitignore — never commit real keys.

# Clerk (auth) — get these from https://dashboard.clerk.com after creating an application
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Gemini API key (Stage 3, free tier) — get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Database connection string (Stage 2) — from Supabase or Neon
DATABASE_URL=

# Your own email (the one you sign in with) - gates access to /admin so
# only you can see aggregate student stats, not any random logged-in user.
ADMIN_EMAIL=

# Your site's real public URL, once you have one (e.g. https://mentora-ai.vercel.app
# or your own domain) - used for the sitemap and robots.txt.
NEXT_PUBLIC_SITE_URL=
