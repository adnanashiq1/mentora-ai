# Copy this file to .env.local and fill in your real values.
# .env.local is already in .gitignore — never commit real keys.

# Clerk (auth) — get these from https://dashboard.clerk.com after creating an application
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Anthropic API key (Stage 3) — get one at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Database connection string (Stage 2) — from Supabase or Neon
DATABASE_URL=
